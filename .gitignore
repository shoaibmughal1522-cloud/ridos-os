# ── live-build output ─────────────────────────────────────────
build-system/binary/
build-system/cache/
build-system/chroot/
build-system/config/binary
build-system/.build/
*.iso
*.img
*.md5
*.sha256

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# ── Secrets — NEVER commit these ──────────────────────────────
*.key
*.pem
*.p12
*.pfx
api.key
.env
.env.*
secrets/
credentials/

# ── OS & Editor junk ──────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
/var/log/

# ── Temporary build files ─────────────────────────────────────
/tmp/
*.tmp
*.bak
*.orig
