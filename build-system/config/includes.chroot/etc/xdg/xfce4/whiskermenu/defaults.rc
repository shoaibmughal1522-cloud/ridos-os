[Configuration]
# RIDOS OS v1.1 — Whisker Menu (App Launcher) Config
# Copyright (C) 2026 RIDOS OS Project — GPL v3
# Location: /etc/xdg/xfce4/whiskermenu/defaults.rc

button-title=RIDOS OS
button-icon=/usr/share/ridos/branding/ridos-icon.svg
show-button-title=true
show-button-icon=true

# Layout
items-per-row=1
item-icon-size=2
hover-switch-category=true
position-search-alternate=true
position-commands-alternate=false

# Behavior
stay-on-focus-out=false
confirm-session-command=true

# Commands shown at bottom of menu
command-settings=xfce4-settings-manager
command-lockscreen=xflock4
command-switchuser=gdmflexiserver
command-logoutdialog=xfce4-session-logout
command-menueditor=menulibre

# Categories shown in sidebar
favorites-count=5
recently-used-count=10

# Custom favorites for IT professionals
[Favorites]
ridos-shell.desktop
xfce4-terminal.desktop
firefox-esr.desktop
thunar.desktop
wireshark.desktop
remmina.desktop
mousepad.desktop
