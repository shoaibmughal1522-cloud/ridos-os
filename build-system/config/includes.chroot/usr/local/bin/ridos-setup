#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# RIDOS OS v1.1 — ridos-setup
# Copyright (C) 2026 RIDOS OS Project — GPL v3
#
# Wrapper to launch setup_wizard.py from anywhere.
# Installed to /usr/local/bin/ridos-setup
#
# Usage:
#   sudo ridos-setup              → run full wizard
#   sudo ridos-setup --api-key    → change API key only
#   sudo ridos-setup --reconfigure → force re-run wizard
# ═══════════════════════════════════════════════════════════════

WIZARD="/opt/ridos/bin/setup_wizard.py"
PYTHON="/usr/bin/python3"

if [ ! -f "$WIZARD" ]; then
  echo "Error: RIDOS setup wizard not found at $WIZARD"
  exit 1
fi

if [ "$1" = "--api-key" ]; then
  # Quick API key update only
  echo ""
  echo "RIDOS OS — API Key Configuration"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  read -rp "  Paste your Anthropic API key: " key
  if [[ "$key" == sk-ant-* ]] && [ ${#key} -gt 30 ]; then
    mkdir -p /etc/ridos
    echo "$key" > /etc/ridos/api.key
    chmod 600 /etc/ridos/api.key
    echo "  ✓ API key saved to /etc/ridos/api.key"
    echo "  ✓ Restart ridos-daemon: sudo systemctl restart ridos-daemon"
  else
    echo "  ✗ Invalid key format. Must start with sk-ant- and be 30+ chars."
    exit 1
  fi
else
  exec "$PYTHON" "$WIZARD" "$@"
fi
