#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# RIDOS OS v1.1 — ridos-shell wrapper
# Copyright (C) 2026 RIDOS OS Project — GPL v3
# Installed to /usr/local/bin/ridos-shell
# ═══════════════════════════════════════════════════════════════

SHELL_PY="/opt/ridos/bin/ridos_shell.py"

# If setup not done yet, run wizard first
if [ ! -f /etc/ridos/.setup_complete ]; then
  echo "RIDOS OS is not configured yet."
  echo "Running setup wizard..."
  sleep 1
  exec sudo python3 /opt/ridos/bin/setup_wizard.py
fi

exec /usr/bin/python3 "$SHELL_PY" "$@"
